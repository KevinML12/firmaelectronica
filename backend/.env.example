DATABASE_URL=postgres://user:pass@localhost:5432/expedientes?sslmode=disable
# true por defecto: aplica backend/migrations/*.up.sql al arrancar (tabla schema_migrations)
AUTO_MIGRATE=true
HTTP_ADDR=:8080
ENV=development
STORAGE_PATH=./data/storage
# CORS_ORIGINS o (alias) CORS_ORIGIN — lista separada por comas
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# URL pública del API; con https:// (si falta, el servidor antepone https://)
PUBLIC_API_URL=http://localhost:8080
SIGN_PIN=2026
PUBLIC_FRONTEND_URL=http://localhost:5173
